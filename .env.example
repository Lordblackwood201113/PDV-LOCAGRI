# ============================================
# PDV Locagri - Variables d'environnement
# ============================================
#
# INSTRUCTIONS:
# 1. Copiez ce fichier vers .env.local
# 2. Remplissez les valeurs avec vos propres clés
# 3. NE COMMITEZ JAMAIS .env.local !
#
# ============================================

# --------------------------------------------
# CONVEX SELF-HOSTED (Backend)
# --------------------------------------------
# Utilisé par la CLI Convex (npx convex deploy, env, etc.)
# La clé admin se génère sur le serveur backend :
#   ./generate_admin_key.sh  (dans le conteneur backend)
#
CONVEX_SELF_HOSTED_URL=https://pdv-convex-api.locagri-app.com
CONVEX_SELF_HOSTED_ADMIN_KEY=pdv|votre_cle_admin

# Utilisé par le client dans le navigateur
VITE_CONVEX_URL=https://pdv-convex-api.locagri-app.com

# --------------------------------------------
# CLERK (Authentification)
# --------------------------------------------
# Clé de PRODUCTION (pk_live) : utilisée par `npm run build`.
# ATTENTION: les clés pk_live ne fonctionnent QUE sur le domaine
# de production (pdv.locagri-app.com), jamais sur localhost.
#
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxx

# Pour le DEV LOCAL: créez .env.development.local avec la clé
# de développement (pk_test) — elle surcharge .env.local
# uniquement pour `npm run dev` :
#
#   VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx

# ============================================
# VARIABLES D'ENVIRONNEMENT DU BACKEND CONVEX
# ============================================
#
# À configurer une fois avec la CLI :
#
#   npx convex env set CLERK_JWT_ISSUER_DOMAIN https://clerk.pdv.locagri-app.com
#   npx convex env set CLERK_JWT_ISSUER_DOMAIN_DEV https://votre-instance.clerk.accounts.dev
#
# CLERK_JWT_ISSUER_DOMAIN     : issuer Clerk production (obligatoire)
# CLERK_JWT_ISSUER_DOMAIN_DEV : issuer Clerk développement (optionnel,
#                               permet l'authentification depuis localhost)
#
# Prérequis Clerk : un JWT Template nommé "convex" doit exister
# dans chaque instance (dev et production).
#
# ============================================
# DÉPLOIEMENT FRONTEND (Cloudflare Pages)
# ============================================
#
# Les variables VITE_* doivent aussi être définies dans les
# settings de build Cloudflare Pages (elles sont intégrées au
# bundle au moment du build) :
#   VITE_CONVEX_URL              = https://pdv-convex-api.locagri-app.com
#   VITE_CLERK_PUBLISHABLE_KEY   = pk_live_xxxxxxxxxxxxx
#
# ============================================
