# ============================================
# PDV Locagri - Variables d'environnement
# ============================================
#
# INSTRUCTIONS:
# 1. Copiez ce fichier vers .env.local
# 2. Remplissez les valeurs avec vos propres clés
# 3. NE COMMITEZ JAMAIS .env.local !
#
# ============================================

# --------------------------------------------
# CONVEX (Backend)
# --------------------------------------------
# 1. Exécutez: npx convex dev
# 2. Créez un compte/projet si nécessaire
# 3. L'URL sera automatiquement ajoutée à .env.local
#
VITE_CONVEX_URL=https://votre-projet.convex.cloud

# --------------------------------------------
# CLERK (Authentification)
# --------------------------------------------
# 1. Créez une application sur https://clerk.com
# 2. Allez dans API Keys
# 3. Copiez la "Publishable Key"
#
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx

# ============================================
# CONFIGURATION CLERK POUR CONVEX (Dashboard)
# ============================================
#
# IMPORTANT: Ces étapes sont OBLIGATOIRES !
#
# 1. Dashboard Clerk > JWT Templates > New template
# 2. Sélectionnez "Convex"
# 3. Nom du template: "convex"
# 4. Copiez l'Issuer URL (ex: https://app.clerk.accounts.dev)
#
# 5. Dashboard Convex > Settings > Environment Variables
# 6. Ajoutez: CLERK_JWT_ISSUER_DOMAIN = [votre Issuer URL]
#
# ============================================
